# ---------------------------------------------------------------------------
# Frontend environment variables (Vite)
#
# Copy this file to `.env` and adjust the values for your setup:
#   cp .env.example .env
#
# Only variables prefixed with VITE_ are exposed to the browser bundle.
# After changing this file, restart the dev server (`yarn dev`).
# ---------------------------------------------------------------------------

# Base URL of the FastAPI backend (no trailing slash).
#
# Examples:
#   Local backend on the same machine:   http://127.0.0.1:8000
#   Dev server proxy (see vite.config):  (leave empty) ""
#   Remote / deployed backend:           http://129.212.191.202:8000
VITE_API_BASE_URL=http://127.0.0.1:8000
