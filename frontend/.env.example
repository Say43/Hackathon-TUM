# ---------------------------------------------------------------------------
# Frontend environment variables (Vite)
#
# Copy this file to `.env` and adjust the values for your setup:
#   cp .env.example .env
#
# Only variables prefixed with VITE_ are exposed to the browser bundle.
# After changing this file, restart the dev server (`npm run dev`).
# ---------------------------------------------------------------------------

# Base URL of the AlphaEarth Explorer FastAPI backend (no trailing slash).
# The frontend is API-only — there is NO proxy and NO localhost fallback.
# Examples:
#   Local backend on the same machine:   http://127.0.0.1:8000
#   Remote / cloud backend:              http://129.212.191.202:8001
#   Vercel preview talking to prod API:  https://alphaearth-api.example.com
VITE_API_BASE_URL=http://127.0.0.1:8000
