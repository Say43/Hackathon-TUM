# ---------------------------------------------------------------------------
# Production environment variables (Vercel)
#
# DO NOT commit real production values. Instead, set these in the Vercel UI:
#   Vercel Dashboard → Project → Settings → Environment Variables
#
# This file exists only as a checklist of the variables that MUST be present
# on the "Production" (and usually "Preview") environment on Vercel.
# ---------------------------------------------------------------------------

# Publicly reachable backend URL (https recommended, no trailing slash).
# The FastAPI backend must allow this Vercel deployment in its CORS origins —
# set `CORS_ORIGINS` on the backend accordingly (see ../backend/README.md).
VITE_API_BASE_URL=https://your-backend-host.example.com
