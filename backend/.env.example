# Copy to backend/.env and edit for your machine.
# python-dotenv loads this on backend startup.

# Root of the Makeathon dataset. Must contain `aef-embeddings/` and `labels/`.
# Relative paths are resolved relative to the repo root, NOT the cwd of uvicorn.
# Example layout this resolves to:
#   $MAKEATHON_DATA_DIR/aef-embeddings/train/18NWG_6_6_2022.tiff
#   $MAKEATHON_DATA_DIR/labels/train/gladl/gladl_18NWG_6_6_alert22.tif
MAKEATHON_DATA_DIR=/home/abdulmoeez/Projects/Hackathon-TUM/model-training/data/abdul-testrun/makeathon-challenge

# Where the AlphaEarth Explorer caches PCA previews, UMAP scatter, and
# trained classifiers. Defaults to `model-training/runs/aef/` (resolved
# from the repo root). Override if you want artifacts on faster disk.
# AEF_CACHE_DIR=/var/cache/alphaearth

# Comma-separated CORS origins (defaults to localhost:5173/4173 + Vercel previews).
# CORS_ORIGINS=https://my-frontend.example.com
